# Copia este archivo a `.env` y completa los valores. NO subas `.env` al repo.

# --- Claude API (obligatorio) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Ajustes del agente (opcional) ---
# Modelo del agente de chat (default: claude-sonnet-4-6)
AGENTE_MODELO=claude-sonnet-4-6
# Esfuerzo del modelo: low | medium | high  (default: medium)
AGENTE_EFFORT=medium

# --- Tienda (Shopify) ---
# Base del sitio para armar los enlaces de carrito (/cart/<variant>:<qty>)
SHOP_BASE_URL=https://www.cercosdeseguridad.cl

# --- Kommo CRM (opcional; sin esto, los leads se registran en modo SIMULADO) ---
# KOMMO_SUBDOMAIN=cds              # de cds.kommo.com (solo el subdominio) — CONFIRMAR
# KOMMO_TOKEN=                     # token de larga duración (integración privada)
# KOMMO_PIPELINE_ID=              # id del embudo "CDS Agente de IA"
# KOMMO_STATUS_ID=               # id de la etapa "Lead entrante"

# --- Seguimiento de conversaciones (opcional) ---
# Minutos de silencio del cliente antes de enviarle UN mensaje de seguimiento (default 45)
# SEGUIMIENTO_MINUTOS=45
# Minutos de silencio antes de registrar el lead de rescate en Kommo (default 240 = 4 h)
# RESCATE_MINUTOS=240
# Horas de pausa del bot cuando un vendedor interviene en la conversación (default 6)
# PAUSA_HUMANO_HORAS=6
# Clave que protege los endpoints /handoff/* (pausa manual y webhook de Kommo)
# HANDOFF_CLAVE=
# MENSAJE_SEGUIMIENTO=Hola, ¿seguimos con tu cotización de cerco? Cualquier duda que tengas, aquí estoy.

# --- WhatsApp (Meta Cloud API) ---
# WHATSAPP_TOKEN=                 # token de acceso (temporal de prueba o permanente de System User)
# WHATSAPP_PHONE_NUMBER_ID=       # ID del número (en la app de WhatsApp de Meta)
# WHATSAPP_VERIFY_TOKEN=          # texto secreto que inventas tú; lo usas al configurar el webhook

# --- Messenger + Instagram (Messenger Platform) ---
# Un mismo token de Página sirve para ambos (IG Business vinculado a la Página).
# PAGE_ACCESS_TOKEN=              # token de la Página (System User; pages_messaging + instagram_manage_messages)
# MESSENGER_VERIFY_TOKEN=        # texto secreto que inventas tú; para verificar el webhook de Page/Instagram
